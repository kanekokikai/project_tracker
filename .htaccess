<IfModule mod_rewrite.c>
    RewriteEngine On

    # 隠しファイル・アプリ内部への直接アクセスを禁止
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor|tools|node_modules)/ - [F,L,NC]
    RewriteRule ^\.env - [F,L,NC]
    RewriteRule ^composer\.(json|lock)$ - [F,L,NC]
    RewriteRule ^package(-lock)?\.json$ - [F,L,NC]
    RewriteRule ^artisan$ - [F,L,NC]

    # public/ 配下へ転送（DocumentRoot がアプリ直下でも Laravel として動作）
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# ディレクトリ一覧を出さない
Options -Indexes
